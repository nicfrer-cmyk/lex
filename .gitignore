node_modules/
dist/
www/

# Phase 1 desktop build output at the repo root (regenerated by `npm run build` in Phase 1;
# superseded by dist/ now that Electron loads the live URL)
/app.js
/platform.js
/template-manager.js

.claude/

# Android (native project itself is committed; build output/caches are not)
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/*.iml
android/captures/

# Never commit real secrets even though supabase-config.js only ever holds the public anon key
.env
.env.local

# Supabase CLI's local link/session cache (contains this machine's project link info,
# not something to share via the repo)
supabase/.temp/
